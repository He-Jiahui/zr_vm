var container = %import("zr.container");
var xs = new container.Array<int>(2);
var map = new container.Map<string, int>();
var obj = {};
var score = 0;

xs.add(10);
xs.add(20);
map["k"] = 30;
obj["k"] = 40;

if (xs[1] == 20) { score = score + 1; }
if (xs[5] == null) { score = score + 10; }
if (map["k"] == 30) { score = score + 100; }
if (map["missing"] == null) { score = score + 1000; }
if (obj["k"] == 40) { score = score + 10000; }
if (obj["missing"] == null) { score = score + 100000; }

return score;
