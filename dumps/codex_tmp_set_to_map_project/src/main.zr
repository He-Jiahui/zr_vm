var container = %import("zr.container");
var {Array, Pair} = %import("zr.container");
var xs = new container.Array<Pair<int, string>>();
xs.add(new container.Pair<int, string>(2, "even"));
xs.add(new container.Pair<int, string>(4, "even"));
var first: Pair<int, string> = xs[0];
var second: Pair<int, string> = xs[1];
var score = 0;
if (first.first == 2) { score = score + 1000; }
if (first.second == "even") { score = score + 100; }
if (second.first == 4) { score = score + 10; }
if (second.second == "even") { score = score + 1; }
return score;
