var benchConfig = %import("bench_config");
var {Array} = %import("zr.container");

var scale = benchConfig.scale();
var length = 16 * scale;
var step = length / 7;
if (step <= 0) {
    step = 1;
}

var checksum = 0;
var pattern = 0;
while (pattern <= 3) {
    var values = new Array<int>();
    var seed = 97;
    var index = 0;

    if (pattern == 0) {
        while (index <= length - 1) {
            seed = (seed * 1103515245 + 12345 + index) % 2147483647;
            values.add(seed % 100000);
            index = index + 1;
        }
    } else if (pattern == 1) {
        while (index <= length - 1) {
            values.add(length - index);
            index = index + 1;
        }
    } else if (pattern == 2) {
        while (index <= length - 1) {
            values.add((index * 17 + 3) % (length / 8 + 5));
            index = index + 1;
        }
    } else {
        while (index <= length - 1) {
            values.add(index * 3 + index % 7);
            index = index + 1;
        }
        index = 0;
        while (index <= length - 1) {
            var swapIndex = (index * 13 + 5) % length;
            var temporary = values[index] + 0;
            var swapValue = values[swapIndex] + 0;
            values[index] = swapValue;
            values[swapIndex] = temporary;
            index = index + 7;
        }
    }

    index = 1;
    while (index <= values.length - 1) {
        var key = values[index] + 0;
        var cursor = index - 1;
        while (cursor >= 0) {
            var cursorValue = values[cursor] + 0;
            if (cursorValue <= key) {
                break;
            }
            values[cursor + 1] = cursorValue;
            cursor = cursor - 1;
        }
        values[cursor + 1] = key;
        index = index + 1;
    }

    var cursor = 0;
    var subtotal = 0;
    while (cursor <= length - 1) {
        var current = values[cursor] + 0;
        subtotal = (subtotal + current * (cursor + 1)) % 1000000007;
        cursor = cursor + step;
    }

    var firstValue = values[0] + 0;
    var middleValue = values[length / 2] + 0;
    var lastValue = values[length - 1] + 0;
    subtotal = (subtotal
            + firstValue * 3
            + middleValue * 5
            + lastValue * 7
            + pattern * 11) % 1000000007;
    checksum = (checksum * 131 + subtotal) % 1000000007;
    pattern = pattern + 1;
}

return "BENCH_SORT_ARRAY_PASS\n" + <string> checksum;
