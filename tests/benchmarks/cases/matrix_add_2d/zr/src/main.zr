var benchConfig = %import("bench_config");
var container = %import("zr.container");

var scale = benchConfig.scale();
var rows = 24 * scale;
var cols = 32 * scale;
var cells = rows * cols;
var lhs = new container.Array<int>();
var rhs = new container.Array<int>();
var dst = new container.Array<int>();
var scratch = new container.Array<int>();
var index = 0;

while (index <= cells - 1) {
    lhs.add(0);
    rhs.add(0);
    dst.add(0);
    scratch.add(0);
    index = index + 1;
}

index = 0;
while (index <= cells - 1) {
    lhs[index] = (index * 13 + 7) % 997;
    rhs[index] = (index * 17 + 11) % 991;
    index = index + 1;
}

var checksum = 0;
var row = 0;
while (row <= rows - 1) {
    var rowSum = 0;
    var col = 0;
    while (col <= cols - 1) {
        var index = row * cols + col;
        dst[index] = lhs[index] + rhs[index] + ((row + col) % 7);
        scratch[index] = dst[index] - lhs[index] / 3 + (rhs[index] % 11);
        rowSum = rowSum + scratch[index] * (col + 1);
        col = col + 1;
    }
    checksum = (checksum + rowSum * (row + 1)) % 1000000007;
    row = row + 1;
}

index = 0;
while (index <= cells - 1) {
    checksum = (checksum + scratch[index] * ((index % 17) + 1)) % 1000000007;
    index = index + 1;
}

return "BENCH_MATRIX_ADD_2D_PASS\n" + <string> checksum;
