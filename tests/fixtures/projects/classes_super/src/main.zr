class BaseCounter {
    pub var baseValue: int;

    pub virtual bump(): int {
        return this.baseValue + 1;
    }

    pub virtual get score: int {
        return this.baseValue + 10;
    }

    pub virtual @call(): int {
        return this.baseValue + 20;
    }
}

class DerivedCounter: BaseCounter {
    pub override bump(): int {
        return super.bump() + 1;
    }

    pub override get score: int {
        return super.score + 2;
    }

    pub override @call(): int {
        return super.call() + 5;
    }

    pub total(): int {
        return this.bump() + this.score + this();
    }
}

var counter = new DerivedCounter();
counter.baseValue = 1;
return counter.total();
