%module "decorators";

%compileTime class Serializable {
    @decorate(target: %type Class): zr.DecoratorPatch {
        return { metadata: { serializable: true } };
    }
}

%compileTime markFunction(target: %type Function, bonus: int = 7) {
    return { metadata: { instrumented: bonus } };
}

%compileTime var registry = {
    nested: {
        mark: markFunction
    }
};
