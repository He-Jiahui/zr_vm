pub var weights: int[%import("sizing").planSize(seed: 4, factor: 2)] = [3,1,4,1,5,9,2,6,5,3,5];

pub fixedChecksum(): int {
    var total = 0;
    var index = 0;
    while (index < weights.length) {
        total = total + weights[index] * (index + 1);
        index = index + 1;
    }
    return total;
}

pub edgeValue(): int {
    return weights[0] + weights[10];
}

pub length(): int {
    return weights.length;
}
