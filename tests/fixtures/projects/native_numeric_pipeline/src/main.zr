var math = import("zr.math");
var system = import("zr.system");
var lin = import("lin_alg");
var signal = import("signal");
var tensor = import("tensor_pipeline");
var io = import("system_io");
var callbacks = import("callbacks");

var summary = callbacks.runCallbacks(lin, signal, tensor);
var output = io.persistReport(summary);

system.console.printLine("NATIVE_NUMERIC_PIPELINE_PASS " + output.banner);
return output.checksum;
