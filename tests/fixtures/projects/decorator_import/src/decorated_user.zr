%module "decorated_user";

var decorators = %import("decorators");
var markClass = decorators.markClass;
var markField = decorators.markField;
var markMethod = decorators.markMethod;
var markProperty = decorators.markProperty;
var markFunction = decorators.markFunction;

#markClass#
pub class User {
    #markField#
    pub var id: int = 1;

    pri var _value: int = 2;

    #markMethod#
    pub load(v: int): int {
        return v;
    }

    #markProperty#
    pub get value: int {
        return this._value;
    }
}

#markFunction#
pub decoratedBonus(): int {
    var meta = %type(decoratedBonus).metadata;
    return meta.instrumented ? 16 : 0;
}

pub var verifyDecorators = () => {
    var seed = 0;
    var typeMeta = %type(User).metadata;
    var fieldMeta = %type(User).members.id[0].metadata;
    var methodMeta = %type(User).members.load[0].metadata;
    var propertyMeta = %type(User).members.value[0].metadata;

    if (typeMeta.runtimeSerializable) {
        seed = seed + 1;
    }
    if (fieldMeta.isRuntimeField) {
        seed = seed + 2;
    }
    if (methodMeta.isRuntimeMethod) {
        seed = seed + 4;
    }
    if (propertyMeta.isRuntimeProperty) {
        seed = seed + 8;
    }

    return seed;
};
