{
  "name": "zr-vm-language-server",
  "publisher": "zr-vm",
  "displayName": "Zr Language Support",
  "description": "Language support for Zr programming language with LSP features",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Debuggers"
  ],
  "activationEvents": [
    "onLanguage:zr",
    "onLanguage:zr-project",
    "onCommand:zr.restartLanguageServer",
    "onCommand:zr.organizeImports",
    "onCommand:zr.richHover.focus",
    "onCommand:zr.richHover.refresh",
    "onCommand:zr.structure.refresh",
    "onCommand:zr.selectProject",
    "onCommand:zr.runCurrentProject",
    "onCommand:zr.showReferences",
    "onCommand:zr.runSelectedProject",
    "onCommand:zr.debugCurrentProject",
    "onCommand:zr.debugSelectedProject",
    "onCommand:zr.attachDebugEndpoint",
    "onView:zrFiles",
    "onView:zrImports",
    "onView:zrBuiltinModules",
    "onView:zrRichHover",
    "onDebugResolve:zr"
  ],
  "main": "./out/extension.js",
  "browser": "./out/browser.js",
  "contributes": {
    "breakpoints": [
      {
        "language": "zr"
      },
      {
        "language": "zr-project"
      }
    ],
    "languages": [
      {
        "id": "zr",
        "aliases": [
          "Zr",
          "zr"
        ],
        "extensions": [
          ".zr"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "zr-project",
        "aliases": [
          "ZR Project",
          "zrp"
        ],
        "extensions": [
          ".zrp"
        ]
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "**/*.zrp",
        "url": "./schemas/zrp.schema.json"
      }
    ],
    "grammars": [
      {
        "language": "zr",
        "scopeName": "source.zr",
        "path": "./syntaxes/zr.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "zr.restartLanguageServer",
        "title": "Restart Language Server",
        "category": "Zr"
      },
      {
        "command": "zr.showReferences",
        "title": "Show References",
        "category": "Zr"
      },
      {
        "command": "zr.organizeImports",
        "title": "Organize Imports",
        "category": "Zr"
      },
      {
        "command": "zr.runCurrentProject",
        "title": "Run Current Project",
        "category": "Zr"
      },
      {
        "command": "zr.runSelectedProject",
        "title": "Run Selected Project",
        "category": "Zr"
      },
      {
        "command": "zr.structure.refresh",
        "title": "Refresh Structure Views",
        "category": "Zr",
        "icon": "$(refresh)"
      },
      {
        "command": "zr.richHover.focus",
        "title": "Open Rich Hover",
        "category": "Zr"
      },
      {
        "command": "zr.richHover.refresh",
        "title": "Refresh Rich Hover",
        "category": "Zr",
        "icon": "$(refresh)"
      },
      {
        "command": "zr.debugCurrentProject",
        "title": "Debug Current Project",
        "category": "Zr"
      },
      {
        "command": "zr.debugSelectedProject",
        "title": "Debug Selected Project",
        "category": "Zr"
      },
      {
        "command": "zr.selectProject",
        "title": "Select Project",
        "category": "Zr"
      },
      {
        "command": "zr.attachDebugEndpoint",
        "title": "Attach to Debug Endpoint",
        "category": "Zr"
      }
    ],
    "debuggers": [
      {
        "type": "zr",
        "label": "ZR Debugger",
        "languages": [
          "zr",
          "zr-project"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "project"
            ],
            "properties": {
              "project": {
                "type": "string",
                "description": "Path to the .zrp project file to launch under zr_vm_cli --debug."
              },
              "cwd": {
                "type": "string",
                "description": "Working directory used when launching zr_vm_cli."
              },
              "executionMode": {
                "type": "string",
                "enum": [
                  "interp",
                  "binary"
                ],
                "default": "interp",
                "description": "ZR execution mode used by zr_vm_cli."
              },
              "cliPath": {
                "type": "string",
                "description": "Optional path to zr_vm_cli. Relative paths resolve against the active workspace folder."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Extra arguments passed through to zr_vm_cli before debug flags are appended."
              },
              "debugAddress": {
                "type": "string",
                "default": "127.0.0.1:0",
                "description": "Loopback endpoint requested from the embedded debugger agent."
              },
              "authToken": {
                "type": "string",
                "description": "Optional auth token forwarded to zrdbg/1 initialize."
              },
              "stopOnEntry": {
                "type": "boolean",
                "default": true,
                "description": "Pause on the initial entry stop emitted by zrdbg/1."
              }
            }
          },
          "attach": {
            "required": [
              "endpoint"
            ],
            "properties": {
              "endpoint": {
                "type": "string",
                "description": "Loopback zrdbg/1 endpoint in host:port form."
              },
              "authToken": {
                "type": "string",
                "description": "Optional auth token forwarded to zrdbg/1 initialize."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "zr",
            "name": "ZR: Launch Project",
            "request": "launch",
            "project": "${workspaceFolder}/project.zrp",
            "cwd": "${workspaceFolder}",
            "executionMode": "interp",
            "stopOnEntry": true
          },
          {
            "type": "zr",
            "name": "ZR: Attach to zrdbg/1 Endpoint",
            "request": "attach",
            "endpoint": "127.0.0.1:9000"
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "zr",
          "title": "ZR",
          "icon": "media/zr-activity.svg"
        }
      ]
    },
    "views": {
      "zr": [
        {
          "id": "zrFiles",
          "name": "Current File Structure"
        },
        {
          "id": "zrImports",
          "name": "Selected Project"
        },
        {
          "id": "zrBuiltinModules",
          "name": "可用模块库"
        },
        {
          "id": "zrRichHover",
          "name": "Rich Hover"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "zr.structure.refresh",
          "when": "view == zrFiles",
          "group": "navigation"
        },
        {
          "command": "zr.structure.refresh",
          "when": "view == zrImports",
          "group": "navigation"
        },
        {
          "command": "zr.structure.refresh",
          "when": "view == zrBuiltinModules",
          "group": "navigation"
        },
        {
          "command": "zr.richHover.refresh",
          "when": "view == zrRichHover",
          "group": "navigation"
        },
        {
          "command": "zr.selectProject",
          "when": "view == zrImports",
          "group": "navigation@1"
        },
        {
          "command": "zr.runSelectedProject",
          "when": "view == zrImports",
          "group": "navigation@2"
        },
        {
          "command": "zr.debugSelectedProject",
          "when": "view == zrImports",
          "group": "navigation@3"
        }
      ],
      "editor/title": [
        {
          "command": "zr.runCurrentProject",
          "when": "resourceExtname == .zrp",
          "group": "navigation"
        },
        {
          "command": "zr.runSelectedProject",
          "when": "resourceExtname == .zr || resourceExtname == .zrp",
          "group": "navigation"
        },
        {
          "command": "zr.debugCurrentProject",
          "when": "resourceExtname == .zrp",
          "group": "navigation"
        },
        {
          "command": "zr.debugSelectedProject",
          "when": "resourceExtname == .zr || resourceExtname == .zrp",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "zr.organizeImports",
          "when": "editorLangId == zr",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Zr Language Server",
      "properties": {
        "zr.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to the default zr_vm_cli executable used for running and debugging .zrp projects. Relative paths resolve against the active workspace folder, then the extension install."
        },
        "zr.languageServer.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Zr language server."
        },
        "zr.languageServer.mode": {
          "type": "string",
          "enum": [
            "auto",
            "native",
            "web"
          ],
          "default": "auto",
          "description": "Select the language server runtime."
        },
        "zr.languageServer.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication with the Zr language server."
        },
        "zr.languageServer.native.path": {
          "type": "string",
          "default": "",
          "description": "Path to a custom zr_vm_language_server_stdio executable. Relative paths resolve against the active workspace folder, then the extension install."
        },
        "zr.debug.cli.path": {
          "type": "string",
          "default": "",
          "description": "Path to a custom zr_vm_cli executable used for ZR desktop debugging. Relative paths resolve against the active workspace folder, then the extension install.",
          "deprecationMessage": "Use zr.executablePath instead. This setting remains as a backward-compatible fallback."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run bundle:servers",
    "clean:out": "node ./scripts/clean-output.js",
    "compile": "npm run clean:out && tsc -p ./ && node ./scripts/build-web-worker.js",
    "watch": "tsc -watch -p ./",
    "build:native": "node ./scripts/build-native-server.js",
    "build:wasm": "node ./scripts/build-wasm-server.js",
    "build:servers": "npm run build:native && npm run build:wasm",
    "sync:native": "node ./scripts/sync-native-server.js",
    "sync:wasm": "node ./scripts/sync-wasm-server.js",
    "sync:servers": "npm run sync:native && npm run sync:wasm",
    "bundle:servers": "npm run build:servers && npm run sync:servers",
    "package:vsix": "powershell -ExecutionPolicy Bypass -File ./scripts/package-vsix.ps1",
    "test:unit": "node --test test/*.test.js",
    "test:e2e:desktop": "npm run compile && npm run build:native && node ./scripts/run-electron-smoke.js",
    "test:e2e:desktop:debug": "npm run compile && npm run build:native && set ZR_TEST_SMOKE_FOCUS=debug&& node ./scripts/run-electron-smoke.js",
    "test:e2e:web": "npm run compile && npm run build:wasm && npm run sync:wasm && node ./scripts/run-web-smoke.js",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.7.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/test-web": "^0.0.80",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-protocol": "^3.17.0"
  }
}
